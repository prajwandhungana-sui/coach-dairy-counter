{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "lib": ["ES2022", "WebWorker"],
    "skipLibCheck": true
  },
  "include": ["vite.config.ts", "tailwind.config.js", "postcss.config.js", "types/**/*.d.ts"]
}